{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/erp-read", "destination": "/api/erp/read" },
    { "source": "/api/erp-action", "destination": "/api/erp/action" },
    { "source": "/api/erp-ai-audit", "destination": "/api/erp/audit" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "crons": [
    { "path": "/api/push/dispatch-alerts", "schedule": "0 7 * * *" }
  ]
}
