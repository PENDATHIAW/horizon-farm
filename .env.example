# Horizon Farm ERP — Variables d'environnement
# Copier ce fichier en .env et renseigner les vraies valeurs

# Supabase (obligatoire)
VITE_SUPABASE_URL=https://xmqfvmswrjhteaijnaxb.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtcWZ2bXN3cmpodGVhaWpuYXhiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgwMTQ0NTcsImV4cCI6MjA5MzU5MDQ1N30.WR0rWE9I3fZJVzdt7UaOzgc_U4UHdsXAf5nsgt_n-7M

# Application (optionnel)
VITE_APP_NAME=Horizon Farm ERP
VITE_APP_ENV=production

# Actions automatiques
# observe = détecte sans modifier les données | on = autorise les anciens moteurs à écrire
VITE_AUTOMATION_WRITE_MODE=observe
# Interrupteur serveur : false suspend paiements automatiques, envois et traitements planifiés
AUTOMATIONS_ENABLED=true

# PWA Push (Vercel → Settings → Environment Variables)
# Générer : npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=<clé publique>
# VAPID_PUBLIC_KEY=<clé publique>
# VAPID_PRIVATE_KEY=<clé privée>
# VAPID_SUBJECT=mailto:contact@horizonfarm.app
# SUPABASE_SERVICE_ROLE_KEY=<service role Supabase>
# CRON_SECRET=<secret aléatoire pour cron + trigger push>

# Paiements Wave / Orange Money (serveur uniquement)
# WAVE_API_KEY=<clé Wave Business>
# WAVE_API_SIGNING_SECRET=<secret de signature des appels Wave, si activé>
# WAVE_WEBHOOK_SECRET=<secret de signature Wave>
# ORANGE_MONEY_API_KEY=<clé Orange Money>
# ORANGE_MONEY_MERCHANT_CODE=<code marchand>
# ORANGE_MONEY_WEBHOOK_SECRET=<secret de confirmation Orange Money>
# MOBILE_MONEY_SANDBOX=true

# Supabase migrations (local / CI uniquement)
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=xmqfvmswrjhteaijnaxb
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xmqfvmswrjhteaijnaxb.supabase.co:5432/postgres
# auto = LLM si les règles échouent | on = toujours tenter LLM | off = règles uniquement (recommandé sans clé OpenAI)
VITE_HEY_HORIZON_LLM=off

# Clé OpenAI (Vercel → Settings → Environment Variables, PAS dans le front)
# Active aussi /api/assistant/generate (relances rédigées par le modèle).
# Sans clé, tout retombe proprement sur les modèles déterministes.
# OPENAI_API_KEY=sk-proj-...
# Alternative dédiée Hey Horizon :
# HEY_HORIZON_LLM_API_KEY=sk-proj-...
# HEY_HORIZON_LLM_BASE_URL=https://api.openai.com/v1
# HEY_HORIZON_LLM_MODEL=gpt-4o-mini
