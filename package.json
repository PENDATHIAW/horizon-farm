{
  "name": "vite-react-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "audit:reachability": "node scripts/audit-source-reachability.mjs",
    "preview": "vite preview",
    "pitch:generate": "node scripts/generate-pitch-assets.mjs",
    "guide:generate": "node scripts/generate-guide-pdf.mjs",
    "test:e2e": "playwright test",
    "test:e2e:workflows": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test tests/e2e/simulated-business-workflows.spec.js",
    "test:e2e:daily-entries": "playwright test tests/e2e/daily-quick-entries.spec.js",
    "test:e2e:smoke": "playwright test tests/e2e/assistant-erp-smoke.spec.js tests/e2e/decision-center-smoke.spec.js",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:roadmap": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test tests/e2e/roadmap-completion.spec.js",
    "test:e2e:push-business": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test tests/e2e/push-and-business-flows.spec.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:unit:i18n": "node --test tests/unit/i18nCharteLibelles.test.js tests/unit/i18nChainesEnDur.test.js",
    "test:unit:demo-financeur": "npx vite-node tests/unit/demoFinanceurDryRun.test.js",
    "test:unit:financements": "npx vite-node tests/unit/financementsWorkflows.test.js",
    "test:unit:kpi-coherence": "npx vite-node tests/unit/kpiCoherenceAudit.test.js",
    "test:unit:ressources": "node --test tests/unit/ressourcesWorkflow.test.js",
    "test:unit:finance": "npx vite-node tests/unit/financePilotage.test.js",
    "test:unit:finance-v1": "npx vite-node tests/unit/financePilotageV1.test.js",
    "test:unit:finance-v2": "npx vite-node tests/unit/financePilotageV2.test.js",
    "test:unit:finance-v3": "npx vite-node tests/unit/financePilotageV3.test.js",
    "test:unit:anti-duplication": "node --test tests/unit/antiDuplicationAudit.test.js",
    "test:unit:commercial": "npx vite-node tests/unit/commercialSaleWorkflow.test.js && npx vite-node tests/unit/commercialV1P0.test.js && npx vite-node tests/unit/commercialV2P1.test.js && npx vite-node tests/unit/commercialV3.test.js",
    "test:unit:elevage": "npx vite-node tests/unit/elevageBroilerScenario.test.js && npx vite-node tests/unit/elevageV1.test.js && npx vite-node tests/unit/elevageV2.test.js && npx vite-node tests/unit/elevageV3.test.js",
    "test:unit:elevage-v3": "npx vite-node tests/unit/elevageV3.test.js",
    "test:unit:cultures": "npx vite-node tests/unit/culturesWorkflow.test.js",
    "test:unit:agri-feeds": "npx vite-node tests/unit/agriFeedsStep1.test.js && npx vite-node tests/unit/agriFeedsStep2.test.js && npx vite-node tests/unit/agriFeedsStep3.test.js && npx vite-node tests/unit/agriFeedsStep4.test.js && npx vite-node tests/unit/agriFeedsStep5.test.js && npx vite-node tests/unit/agriFeedsStep6.test.js && npx vite-node tests/unit/agriFeedsReadiness.test.js && npx vite-node tests/unit/agriFeedsRenderSmoke.test.js",
    "test:unit:documents": "node --test tests/unit/documentsWorkflow.test.js",
    "test:unit:activite": "node --test tests/unit/activiteSuiviWorkflow.test.js",
    "test:unit:centre": "node --test tests/unit/centreObjectifsWorkflow.test.js",
    "test:unit:dashboard": "npx vite-node tests/unit/dashboardPilotage.test.js && npx vite-node tests/unit/dashboardMetrics.test.js && npx vite-node tests/unit/dashboardHealthCache.test.js && npx vite-node tests/unit/dashboardV3.test.js && npx vite-node tests/unit/carnetHorizon.test.js && node --test tests/unit/dashboardAccueilUx.test.js",
    "test:unit:farm-scope": "node --test tests/unit/farmScope.test.js tests/unit/farmScopePhase3.test.js tests/unit/farmScopePhase4.test.js tests/unit/farmScopePhase5.test.js",
    "test:unit:workflow-quality": "npx vite-node tests/unit/workflowQualityAudit.test.js",
    "test:unit:workflow-impact": "node tests/unit/workflowImpactJournal.test.js",
    "test:unit:justified-exceptions": "node tests/unit/justifiedExceptionStore.test.js",
    "test:unit:guided-repairs": "npx vite-node tests/unit/syncGuidedRepairActions.test.js",
    "test:unit:idempotency": "node --test tests/unit/workflowIdempotency.test.js",
    "test:unit:daily-entries": "npx vite-node tests/unit/dailyQuickEntryContract.test.js",
    "test:unit:module-smoke": "npx vite-node tests/unit/moduleImportSmoke.test.js",
    "test:unit:business-events": "npx vite-node tests/unit/businessEventOperationalGaps.vite.js && node --test tests/unit/businessInterconnectionsCoverage.test.js tests/unit/businessEventImplementationAudit.test.js",
    "test:unit:render-smoke": "npx vite-node tests/unit/moduleRenderSmoke.test.js && npx vite-node tests/unit/moduleMissingImports.test.js && npx vite-node tests/unit/investorRoomPanels.test.js && npx vite-node tests/unit/appModuleProps.test.js && node --test tests/unit/farmAdaptationNull.test.js",
    "test:unit:commercial-simulated": "npx vite-node tests/unit/commercialSimulatedMode.test.js",
    "test:unit:commercial-subscriptions": "npx vite-node tests/unit/commercialSubscriptionsPanel.test.js",
    "test:unit:stability": "npx vite-node tests/unit/moduleStabilityRegression.test.js && npx vite-node tests/unit/financeInvestissementsRegression.test.js && npx vite-node tests/unit/moduleRenderWithProvider.vite.test.js && npx vite-node tests/unit/commercialModuleTabsRegression.test.js && npx vite-node tests/unit/commercialSimulatedMode.test.js && npx vite-node tests/unit/moduleTabsStability.test.js && npx vite-node tests/unit/bpExcelProtection.test.js",
    "test:unit:module-tabs-stability": "npx vite-node tests/unit/moduleTabsStability.test.js",
    "test:unit:bp-excel-protection": "npx vite-node tests/unit/bpExcelProtection.test.js",
    "test:unit:annexe-tabs": "node --test tests/unit/annexeTabsConfig.test.js",
    "test:unit:achats-stock": "npx vite-node tests/unit/stockPurchaseWorkflow.test.js && npx vite-node tests/unit/achatsStockV1P0.test.js && npx vite-node tests/unit/achatsStockV2.test.js && npx vite-node tests/unit/achatsStockV3.test.js",
    "test:unit:bp-concretisation": "npx vite-node tests/unit/bpLineConcretization.test.js",
    "test:unit:bp-import": "npx vite-node tests/unit/bpImportDispatch.test.js",
    "test:unit:bp-excel": "npx vite-node tests/unit/bpExcelParser.test.js",
    "test:unit:hey-horizon-core": "npx vite-node tests/unit/heyHorizonCore.test.js",
    "test:unit:whatsapp-horizon": "npx vite-node tests/unit/whatsappHorizon.test.js",
    "test:unit:ai-gateway": "node --test tests/unit/aiGateway.test.js",
    "test:unit:document-scanner": "node --test tests/unit/documentScanner.test.js",
    "test:unit:contextual-voice": "node --test tests/unit/contextualVoice.test.js",
    "test:unit:chart-explain": "node --test tests/unit/chartExplain.test.js",
    "test:unit:sales-publication": "npx vite-node tests/unit/salesPublication.test.js",
    "db:migrate": "bash scripts/apply_supabase_migrations.sh",
    "db:migrate:verify": "node scripts/apply_supabase_migrations.mjs",
    "check": "npm run lint && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "pg": "^8.21.0",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10"
  }
}
